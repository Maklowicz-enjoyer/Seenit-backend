# Skopiuj do .env  (cp .env.example .env) i USTAW własne hasło + SECRET_KEY.
# .env NIE trafia do gita.

# --- baza ---
POSTGRES_USER=seenit
POSTGRES_PASSWORD=ZMIEN_TO_haslo
POSTGRES_DB=seenit

# URL używany przez API WEWNĄTRZ kontenera -> host to "db", port 5432.
# UWAGA: jeśli zmienisz POSTGRES_PASSWORD wyżej, zmień je też TUTAJ (po @ ... :).
DATABASE_URL=postgresql+psycopg2://seenit:ZMIEN_TO_haslo@db:5432/seenit

# --- aplikacja ---
SECRET_KEY=wygeneruj_losowy_ciag_np_openssl_rand_hex_32
